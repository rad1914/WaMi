package com.radwrld.wami.model

data class Message(
    // CRITICAL FIX: 'var' allows updating the ID from a temporary to a real one.
    var id: String,
    val jid: String,
    val text: String,
    val name: String,
    // CRITICAL FIX: 'var' allows updating the status (e.g., sending -> sent).
    var status: String,
    val isOutgoing: Boolean,
    val timestamp: Long
)
