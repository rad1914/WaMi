<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Wami" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item> <!-- Should be bold and vibrant -->
        <item name="colorOnPrimary">@color/onPrimary</item> <!-- Good contrast, typically white or light gray -->

        <item name="colorPrimaryContainer">@color/primaryContainer</item> <!-- A slightly muted or lighter version of primary -->
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item> <!-- Keep contrast high for readability -->

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item> <!-- Can be complementary or analogous to primary -->
        <item name="colorOnSecondary">@color/onSecondary</item> <!-- High contrast for legibility -->

        <!-- Background and Surface Colors -->
        <item name="android:colorBackground">@color/background</item> <!-- Typically a very dark tone -->
        <item name="colorOnBackground">@color/onBackground</item> <!-- Light color for text, should stand out against background -->
        
        <item name="colorSurface">@color/surface</item> <!-- Slightly darker than background for card-like surfaces -->
        <item name="colorOnSurface">@color/onSurface</item> <!-- High contrast text for readability on dark surfaces -->
        
        <item name="colorSurfaceVariant">@color/surfaceVariant</item> <!-- Optional, can be a lighter/darker shade for variation -->
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant</item> <!-- Should contrast well for any text/icons on variant surfaces -->

        <!-- Outline Color -->
        <item name="colorOutline">@color/outline</item> <!-- Usually a subtle accent, used for borders -->

        <!-- Status Bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item> <!-- Keep aligned with surface color or use a slightly darker shade -->
    </style>
</resources>
