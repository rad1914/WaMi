<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Wami" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/bg_primary</item>

        <!-- Surface -->
        <item name="colorSurface">@color/bg_bottom_nav</item>
        <item name="colorOnSurface">@color/nav_item_active</item>

        <!-- Status bar -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/purple_700</item>

        <!-- Divider -->
        <item name="colorSurfaceVariant">@color/divider</item>

        <!-- Standard Android text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

    </style>

</resources>
