<?xml version="1.0" encoding="utf-8"?>
<!-- @path: app/src/main/res/layout/activity_settings.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".SettingsActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textAppearance="?attr/textAppearanceHeadline4"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

<com.google.android.material.switchmaterial.SwitchMaterial
    android:id="@+id/enable_custom_ip_switch"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Enable custom IP"
    android:textAppearance="?attr/textAppearanceBodyLarge"
    android:contentDescription="Toggle custom IP setting"/>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Once enabled, the app will connect to your custom Backend, allowing running it directly in your own machine for improved privacy"
        android:textAppearance="?attr/textAppearanceBody2"
        android.layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/set_custom_ip_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set custom IP >"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        android:visibility="gone"
        tools:visibility="visible"/>

</LinearLayout>
